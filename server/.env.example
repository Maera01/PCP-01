# Copie este arquivo para server/.env no seu computador ou cadastre estas
# variaveis no painel do Render/servico onde o backend roda.

# URL do banco Neon. Use a string completa fornecida pelo Neon.
DATABASE_URL=postgresql://usuario:senha@host/neondb?sslmode=require

# Schema exclusivo deste aplicativo dentro do mesmo banco Neon.
# O servidor cria este schema automaticamente ao iniciar.
DB_SCHEMA=controle_producao

# Neon usa SSL.
PGSSLMODE=require

# Porta local do backend.
PORT=3000

# Senha master opcional. Se existir, use login "master" com esta senha.
# Esta senha nao e gravada no banco.
MAERA_MASTER_PASSWORD=troque-esta-senha
